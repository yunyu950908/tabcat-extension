{
  "name": "tabcat-extension",
  "description": "A Chrome extension for domain-based tab grouping, cleanup, and fast tab switching.",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.2",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "test": "vitest run",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "check:built-version": "node scripts/check-built-version.mjs",
    "check:release-version": "node scripts/check-release-version.mjs",
    "release:prepare-artifact": "node scripts/prepare-release-artifact.mjs",
    "release:patch": "pnpm version patch --no-git-tag-version",
    "release:minor": "pnpm version minor --no-git-tag-version",
    "release:major": "pnpm version major --no-git-tag-version",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tldts": "^7.4.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  }
}
